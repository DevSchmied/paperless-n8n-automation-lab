      "name": "Datei laden",
      "credentials": {
        "httpHeaderAuth": {
          "id": "YOUR_N8N_PAPERLESS_HEADER_AUTH_CREDENTIAL_ID",
          "name": "YOUR_N8N_PAPERLESS_HEADER_AUTH_CREDENTIAL_NAME"
        }
      }
    },
    {
      "parameters": {
        "mode": "combine",
        "combineBy": "combineByPosition",
        "options": {}
      },
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3.2,
      "position": [
        1104,
        320
      ],
      "id": "NODE_ID_DOKUMENTDATEN_UND_DATEI_ZUSAMMENFUHREN_PLACEHOLDER",
      "name": "Dokumentdaten und Datei zusammenführen"
    },
    {
      "parameters": {
        "operation": "write",
        "fileName": "=/files/tmp/paperless-ki-ocr-{{$json.id}}.pdf",
        "options": {}
      },
      "type": "n8n-nodes-base.readWriteFile",
      "typeVersion": 1.1,
      "position": [
        1296,
        320
      ],
      "id": "NODE_ID_PDF_TEMPORAR_SPEICHERN_PLACEHOLDER",
      "name": "PDF temporär speichern"
    },
    {
      "parameters": {
        "command": "=set -eu\n\nDOC_ID=\"{{ $json.id }}\"\nPDF=\"/files/tmp/paperless-ki-ocr-${DOC_ID}.pdf\"\nDIR=\"/files/tmp/paperless-ki-ocr-${DOC_ID}\"\n\ntest -f \"$PDF\"\n\nrm -rf \"$DIR\"\nmkdir -p \"$DIR\"\n\npdftoppm \\\n  -png \\\n  -r 200 \\\n  \"$PDF\" \\\n  \"$DIR/page\"\n\nPAGE_COUNT=\"$(find \"$DIR\" -maxdepth 1 -type f -name 'page-*.png' | wc -l | tr -d ' ')\"\n\ntest \"$PAGE_COUNT\" -gt 0\n\nprintf 'document_id=%s\\npage_count=%s\\ndirectory=%s\\n' \\\n  \"$DOC_ID\" \\\n  \"$PAGE_COUNT\" \\\n  \"$DIR\""
      },
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        1472,
        320
      ],
      "id": "NODE_ID_PDF_IN_PNG_SEITEN_UMWANDELN_PLACEHOLDER",
      "name": "PDF in PNG-Seiten umwandeln"
    },
    {
      "parameters": {
        "fileSelector": "={{ '/files/tmp/paperless-ki-ocr-' + $('Dokumentdaten und Datei zusammenführen').first().json.id + '/page-*.png' }}",
        "options": {}
      },
      "type": "n8n-nodes-base.readWriteFile",
      "typeVersion": 1.1,
      "position": [
        1632,
        320
      ],
      "id": "NODE_ID_PNG_SEITEN_LADEN_PLACEHOLDER",
      "name": "PNG-Seiten laden"
    },
    {
      "parameters": {
        "jsCode": "const document =\n  $('Dokumentdaten und Datei zusammenführen').first().json;\n\nreturn $input.all().map((item, index) => {\n  const fileName =\n    item.binary?.data?.fileName ??\n    `page-${index + 1}.png`;\n\n  const match = fileName.match(/page-(\\d+)\\.png$/i);\n\n  return {\n    json: {\n      document_id: document.id,\n      title: document.title ?? '',\n      original_file_name:\n        document.original_file_name ??\n        document.filename ??\n        '',\n\n      original_content:\n        document.content ?? '',\n\n      original_custom_fields:\n        Array.isArray(document.custom_fields)\n          ? document.custom_fields\n          : [],\n\n      page_number:\n        match\n          ? Number(match[1])\n          : index + 1,\n\n      page_file_name: fileName,\n    },\n\n    binary: item.binary,\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1808,
        320
      ],
      "id": "NODE_ID_SEITENMETADATEN_ERGANZEN_PLACEHOLDER",
      "name": "Seitenmetadaten ergänzen"
    },
    {
      "parameters": {
        "sortFieldsUi": {
          "sortField": [
            {
              "fieldName": "page_number"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.sort",
      "typeVersion": 1,
      "position": [
        2016,
        320
      ],
      "id": "NODE_ID_SEITEN_SORTIEREN_PLACEHOLDER",
      "name": "Seiten sortieren"
    },
    {
      "parameters": {
        "options": {}
      },
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [
        2224,
        320
      ],
      "id": "NODE_ID_SEITEN_EINZELN_VERARBEITEN_PLACEHOLDER",
      "name": "Seiten einzeln verarbeiten"
    },
    {
      "parameters": {
        "operation": "binaryToPropery",
        "destinationKey": "image_base64",
        "options": {}
      },
      "type": "n8n-nodes-base.extractFromFile",
      "typeVersion": 1.1,
      "position": [
        2400,
        464
      ],
      "id": "NODE_ID_SEITENBILD_ZU_BASE64_PLACEHOLDER",
      "name": "Seitenbild zu Base64"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const page =\n  $('Seiten einzeln verarbeiten').item.json;\n\nreturn {\n  json: {\n    ...page,\n    image_base64: $json.image_base64,\n  },\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2576,
        320
      ],
      "id": "NODE_ID_BASE64_METADATEN_ERGANZEN_PLACEHOLDER",
      "name": "Base64-Metadaten ergänzen"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://YOUR_OLLAMA_HOST:11434/api/chat",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ ({\n  model: 'glm-ocr',\n  stream: false,\n  keep_alive: 0,\n  options: {\n    temperature: 0\n  },\n  messages: [\n    {\n      role: 'user',\n      content: `Analysiere diese einzelne Dokumentseite.\n\nAufgaben:\n1. Erkenne den vollständigen sichtbaren Text.\n2. Erhalte Überschriften, Absätze und Listen.\n3. Gib erkannte Tabellen als Markdown-Tabellen zurück.\n4. Beschreibe die Dokumentstruktur.\n5. Erfinde keine Inhalte.\n6. Markiere tatsächlich unlesbare Stellen mit [unlesbar].\n7. Wiederhole keine Inhalte unnötig.\n\nAntworte ausschließlich als gültiges JSON in dieser Struktur:\n\n{\n  \"text_markdown\": \"...\",\n  \"tables_markdown\": [],\n  \"document_structure\": [],\n  \"figures\": [],\n  \"warnings\": []\n}`,\n      images: [$json.image_base64]\n    }\n  ]\n}) }}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        2736,
        464
      ],
      "id": "NODE_ID_GLM_OCR_SEITE_ANALYSIEREN_PLACEHOLDER",
      "name": "GLM-OCR Seite analysieren"
    },
